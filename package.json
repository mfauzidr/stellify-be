{
  "name": "stellify-be",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf /dist",
    "build": "npm run clean && tsc --build && cp -r ./node_modules ./dist/node_modules",
    "start": "node ./dist/index.js",
    "dev:local": "cross-env NODE_ENV=local ts-node-dev --respawn --transpile-only -r tsconfig-paths/register api/index.ts",
    "dev:prod": "cross-env NODE_ENV=production ts-node-dev --respawn --transpile-only -r tsconfig-paths/register api/index.ts",
    "knex": "knex --knexfile src/shared/config/knexfile.ts",
    "migrate": "npm run knex migrate:latest",
    "seed": "npm run knex seed:run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "morgan": "^1.11.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
